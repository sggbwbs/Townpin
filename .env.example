# Stripe (Developers -> API keys, and Developers -> Webhooks)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase (Project Settings -> API)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic (console.anthropic.com -> API Keys) — powers the AI content check.
# Optional: leave unset and the check is skipped.
ANTHROPIC_API_KEY=sk-ant-...

# Admin page (townpin.vercel.app/admin) — see scripts/hash-password.js to
# generate ADMIN_PASSWORD_HASH from your own chosen password without ever
# sending the real password anywhere. ADMIN_TOKEN_SECRET can be any long
# random string (e.g. generate one at random.org or `openssl rand -hex 32`).
ADMIN_PASSWORD_HASH=$2a$12$...
ADMIN_TOKEN_SECRET=replace-with-a-long-random-string

# Your deployed site URL (no trailing slash)
SITE_URL=https://townpin.vercel.app
